<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Don't back up captured RAW frames — they're large and device-specific -->
        <exclude domain="file" path="captures/"/>
        <exclude domain="file" path="stacked/"/>
        <!-- Do back up the Room database (session metadata) -->
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="captures/"/>
        <exclude domain="file" path="stacked/"/>
    </device-transfer>
</data-extraction-rules>
